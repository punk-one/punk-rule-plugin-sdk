{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug current package (main only)",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${fileDirname}",
            "cwd": "${workspaceFolder}",
            "env": {
                "GOROOT": "/home/sun/.g/go",
                "GOPATH": "/home/sun/go",
                "GOTOOLCHAIN": "local",
                "PATH": "/home/sun/.g/bin:/home/sun/.g/go/bin:/home/sun/go/bin:${env:PATH}"
            }
        },
        {
            "name": "Debug current package tests",
            "type": "go",
            "request": "launch",
            "mode": "test",
            "program": "${fileDirname}",
            "cwd": "${workspaceFolder}",
            "env": {
                "GOROOT": "/home/sun/.g/go",
                "GOPATH": "/home/sun/go",
                "GOTOOLCHAIN": "local",
                "PATH": "/home/sun/.g/bin:/home/sun/.g/go/bin:/home/sun/go/bin:${env:PATH}"
            }
        }
    ]
}
